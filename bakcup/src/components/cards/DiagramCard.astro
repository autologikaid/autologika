---
import Card from "../ui/Card.astro";
import "../../styles/cards/diagram-card.css";

const {
    title,
    description,
    thumbnail,
    diagramNumber,
    href = "#",
} = Astro.props;
---

<Card>

    <a href={href} class="diagram-thumbnail">

        <img
            src={thumbnail}
            alt={title}
        />

    </a>

    <div class="diagram-card-body">

        <span class="diagram-number">

            Diagram #{diagramNumber}

        </span>

        <h3>{title}</h3>

        <p>{description}</p>

        <a href={href} class="diagram-link">

            Lihat Diagram →

        </a>

    </div>

</Card>