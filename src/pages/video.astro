---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/sections/Navbar.astro";
import VideoCard from "../components/cards/VideoCard.astro";
import "../styles/sections/featured-video.css";
import { videos } from "../data/videos";
---

<BaseLayout title="Video | AutoLogika">

    <Navbar />

    <section class="section">

        <div class="container">

            <h1>🎥 Semua Video</h1>

            <p>
                Belajar otomotif modern melalui video interaktif AutoLogika.
            </p>

            <div class="video-grid">

                {
                    videos.map(video => (

                        <VideoCard {...video} />

                    ))
                }

            </div>

        </div>

    </section>

</BaseLayout>