---
import "../../styles/hero/hero-blueprint.css";
---

<div class="hero-scene">

    <!-- Background -->

    <div class="scene-grid">

        <img
        src="/images/hero/technology-grid.svg"
        alt=""
        />

    </div>

    <div class="scene-circuit">
        
        <img
        src="/images/hero/circuit-pattern.svg"
        alt=""
        />
    
    </div>

    <div class="scene-glow"></div>


    <!-- HUD -->

    <div class="scene-hud">
        
        <img
        src="/images/hero/hud-circle.svg"
        alt=""
        />
    
    </div>


    <!-- Blueprint Mobil -->

    <div class="scene-car">

        <img
            src="/images/hero/blueprint-car.svg"
            alt="Blueprint Mobil"
        />

    </div>


    <!-- ECU -->

    <div class="scene-ecu">
        <img
        src="/images/hero/ecu-chip.svg"
        alt="ECU"
        />
    </div>

    <!-- Sensor -->

    <div class="sensor maf">

        MAF

    </div>

    <div class="sensor map">

        MAP

    </div>

    <div class="sensor tps">

        TPS

    </div>

    <div class="sensor iat">

        IAT

    </div>

    <div class="sensor ect">

        ECT

    </div>

    <div class="sensor o2">

        O2

    </div>

    <div class="sensor ckp">

        CKP

    </div>

    <div class="sensor cmp">

        CMP

    </div>

</div>