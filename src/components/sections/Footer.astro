---
import "../../styles/footer.css";
---

<footer class="footer">

    <div class="container footer-grid">

        <!-- BRAND -->

        <section class="footer-brand">

            <img
                src="/logo.webp"
                alt="AUTOLOGIKA.ID"
                class="footer-logo"
            />

            <p class="footer-description">

                Belajar otomotif modern melalui video,
                infografis, dan artikel yang mudah dipahami.

            </p>

            <div class="footer-social">

        <a
        href="https://www.youtube.com/@AutoLogikaID"
        target="_blank"
        rel="noopener noreferrer">
            
                <div class="social-left">
                    <img
                    src="/images/social/youtube.webp"
                    alt="YouTube"
                    />
                
                <span>YouTube</span>
            </div>
            <span class="social-user">
                @AutoLogikaID
            </span>
        
        </a>

        <a
        href="https://www.instagram.com/autologika.id"
        target="_blank"
        rel="noopener noreferrer">

            <div class="social-left">
                <img
                src="/images/social/instagram.webp"
                alt="Instagram"
                />
                <span>Instagram</span>
            </div>
            
            <span class="social-user">
                @autologika.id
            </span>
        </a>

        <a
        href="https://www.facebook.com/p/AutoLogikaID-61591074907447/"
        target="_blank"
        rel="noopener noreferrer">

            <div class="social-left">
                <img
                src="/images/social/facebook.webp"
                alt="Facebook"
                />                
                <span>Facebook</span>
            </div>
            
            <span class="social-user">
                AutoLogika.ID
            </span>
        </a>

        <a
        href="https://www.tiktok.com/@autologika.id"
        target="_blank"
        rel="noopener noreferrer">
            
                <div class="social-left">
                    <img
                    src="/images/social/tiktok.webp"
                    alt="TikTok"
                    />
                
                <span>TikTok</span>
            </div>
            <span class="social-user">
                @autologika.id
            </span>
        
        </a>
    </div>

        </section>

        <!-- MENU -->

        <section>

            <h3>Jelajahi</h3>

            <ul>

                <li><a href="/">Home</a></li>
                <li><a href="/video">Video</a></li>
                <li><a href="/diagram">Infografis</a></li>
                <li><a href="/article">Artikel</a></li>
                <li><a href="/about">Tentang</a></li>
                <li><a href="/kontak">Kontak</a></li>

            </ul>

        </section>

        <!-- ROADMAP -->

        <section>

            <h3>Roadmap</h3>

            <ul>

                <li>✅ Video Edukasi</li>
                <li>✅ Diagram Berseri</li>
                <li>✅ Website</li>
                <li>🚧 Artikel</li>
                <li>🧪 Simulator Interaktif</li>

            </ul>

        </section>

    </div>

    <div class="footer-bottom">

        <div class="container">

            <div class="footer-status">

                <span class="status-dot"></span>

                Website Online

                <span class="version">

                    v1.0.0

                </span>

            </div>

            <p class="footer-tagline">

                "Memahami kendaraan dimulai dari memahami cara berpikirnya."

            </p>

            <p class="footer-copy">

                © 2026 AutoLogika.id • Built with Astro & Cloudflare

            </p>

        </div>

    </div>

</footer>