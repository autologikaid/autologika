---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  fullWidth?: boolean;
}

const {
  href = "#",
  variant = "primary",
  size = "md",
  fullWidth = false,
} = Astro.props;
---

<a
    href={href}
    class={`btn btn-${variant} btn-${size} ${fullWidth ? "btn-full" : ""}`}
>
    <slot />
</a>

<style>

.btn{

display:inline-flex;

align-items:center;

justify-content:center;

gap:10px;

border-radius:16px;

text-decoration:none;

font-weight:700;

transition:.3s;

}

.btn-sm{

padding:10px 18px;

font-size:.9rem;

}

.btn-md{

padding:14px 28px;

font-size:1rem;

}

.btn-lg{

padding:18px 36px;

font-size:1.1rem;

}

.btn-full{

width:100%;

}

.btn-primary{

    background:var(--primary);

    color:white;

}

.btn-secondary{

    border:1px solid rgba(255,255,255,.15);

    background:rgba(255,255,255,.04);

    color:white;

}

.btn-ghost{

    color:var(--text);

}

.btn:hover{

    transform:translateY(-4px);

}

</style>