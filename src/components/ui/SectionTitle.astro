---
interface Props {
    title: string;
    href?: string;
    action?: string;
}

const {
    title,
    href,
    action = "Lihat Semua →"
} = Astro.props;
---

<div class="section-title">

    <h2>{title}</h2>

    {
        href && (
            <a href={href}>{action}</a>
        )
    }

</div>

<style>

.section-title{

display:flex;

justify-content:space-between;

align-items:center;

margin-bottom:40px;

}

.section-title h2{

font-size:2rem;

font-weight:700;

color:var(--text);

}

.section-title a{

color:var(--primary);

text-decoration:none;

font-weight:600;

transition:.25s;

}

.section-title a:hover{

opacity:.8;

}

</style>