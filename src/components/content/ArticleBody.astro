---
import type { Article } from "../../types/content";

interface Props {
    content: Article;
}

const { content } = Astro.props;
---

<div class="article-card">

    <article class="article-body">
        
        <div class="article-hero">
            <div class="article-hero-label">
                AUTOLOGIKA.ID ARTICLE
            </div>
            <img
            class="article-cover"
            src={content.image}
            alt={content.title}
            />
        </div>

        <Fragment set:html={content.body} />
    
    </article>

</div>

<style is:global>

.article-card{

    background:#ffffff;

    color:#111;

    border-radius:40px;

    padding:40px;

    margin-top:20px;

    box-shadow:0 12px 35px rgba(0,0,0,.25);

}

.article-hero{

    position:relative;

    background:linear-gradient(
        180deg,
        #fafafa,
        #f3f4f6
    );

    border:1px solid rgba(193,18,31,.15);

    border-radius:26px;

    padding:32px;

    margin:10px auto 50px;

    box-shadow:
        0 18px 45px rgba(0,0,0,.10),
        0 0 30px rgba(193,18,31,.05);

}

.article-hero-label{

    display:inline-flex;

    align-items:center;

    padding:8px 16px;

    margin-bottom:24px;

    border-radius:999px;

    background:rgba(193,18,31,.08);

    color:var(--primary);

    font-size:.75rem;

    font-weight:700;

    letter-spacing:.14em;

    text-transform:uppercase;

}

.article-body{

    max-width:800px;

    margin:auto;

    line-height:1.6;

    font-size:1rem;

}

.article-body figure{

    margin:36px auto;

    text-align:center;

}

.article-body figcaption{

    margin-top:12px;

    font-size:.9rem;

    color:#666;

    font-style:italic;

}

.article-body h2{

    color:#111;

    margin-top:1rem;

}

.article-body p{

    color:#444;

    text-align: justify;

    line-height:2;

    margin-bottom:1.4rem;

}

.article-body figure img{

    display:block;

    max-width:260px;

    width:100%;

    margin:20px auto;

    border-radius:16px;

    cursor:pointer;

    transition:.25s;

}

.article-body figure.article-diagram img{

    width:100%;

    max-width:760px;

    height:auto;

    display:block;

    margin:24px auto;

    border-radius:18px;

}

.article-cover{

    display:block;

    width:70%;

    max-width:640px;

    margin:auto;

    border-radius:18px;

}

.article-body figure img:hover{

    transform:scale(1.03);

}

@media(max-width:768px){

.article-card{

    padding:28px;

}

.article-hero{

    padding:20px;

}

.article-cover{

    width:100%;

}

.article-hero-label{

    font-size:.68rem;

}

}

/* ========================================
   TABEL ARTIKEL
======================================== */

.article-body table{
    width:100%;
    margin:40px 0;
    border-collapse:separate;
    border-spacing:0;
    overflow:hidden;
    border:1px solid #e5e7eb;
    border-radius:16px;
    background:#fff;
    box-shadow:0 8px 24px rgba(0,0,0,.06);
}

.article-body thead{
    background:var(--primary);
    color:#fff;
}

.article-body th{
    padding:16px 20px;
    text-align:left;
    font-weight:700;
    font-size:1rem;
}

.article-body td{
    padding:16px 20px;
    border-top:1px solid #ececec;
    vertical-align:top;
    line-height:1.8;
}

.article-body tr td:first-child,
.article-body tr th:first-child{
    border-right:1px solid #ececec;
}

.article-body tbody tr:nth-child(even){
    background:#fafafa;
}

.article-body table strong{
    color:#111;
}

@media(max-width:768px){

.article-body table{
    display:block;
    overflow-x:auto;
    white-space:nowrap;
}

}

/* ========================================
   AUTOLOGIKA NOTE
======================================== */

.article-body blockquote{

    margin:36px 0;

    padding:20px 24px;

    background:#fff8f8;

    border-left:5px solid var(--primary);

    border-radius:0 12px 12px 0;

    color:#444;

    line-height:1.8;

}

.article-body blockquote strong{

    color:var(--primary);

    font-size:1rem;

}

</style>