---
import "../../styles/content/related-videos.css";

import type { Video } from "../../types/content";

import VideoCard from "../cards/VideoCard.astro";

const {
    currentSlug,
    videos,
} = Astro.props as {
    currentSlug: string;
    videos: Video[];
};

const related = videos
    .filter(video => video.slug !== currentSlug)
    .slice(0, 3);
---

<section class="related-videos">

    <h2>Video Lainnya</h2>

    <div class="related-grid">

        {
            related.map(video => (
                <VideoCard {...video} />
            ))
        }

    </div>

</section>