---
import "../../styles/content/content-header.css";

const { content } = Astro.props;

const timeInfo =
    content.duration ??
    content.readingTime ??
    null;
---

<header class="content-header">

    <div class="content-meta">

        <span class="badge">
            {content.category}
        </span>

        <span class="badge">
            {content.level}
        </span>

    </div>

    <h1>
        {content.title}
    </h1>

    <div class="content-info">

        <span>
            📅 {content.publishedAt}
        </span>

        {timeInfo && (
            <span>
                ⏱ {timeInfo}
            </span>
        )}

    </div>

    <p class="content-description">
        {content.excerpt}
    </p>

</header>